# Copiez ce fichier en ".env" puis remplissez vos valeurs Supabase.
# Dashboard Supabase > Project Settings > API
#
# IMPORTANT : utilisez la clé "anon" au format JWT (commence par eyJ...).
# Les nouvelles clés "sb_publishable_..." ne sont PAS acceptées par
# supabase-py 2.9.1 (erreur "Invalid API key").

SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_KEY=eyJ...votre_cle_anon_complete...
